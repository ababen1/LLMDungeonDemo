# Default provider: groq
VITE_LLM_PROVIDER=groq
VITE_LLM_API_KEY=gsk_your-groq-key-here
VITE_LLM_MODEL=llama-3.3-70b-versatile
VITE_LLM_BASE_URL=https://api.groq.com/openai

# Local network LLM (set VITE_LLM_PROVIDER=local for testing)
# VITE_LLM_PROVIDER=local
# VITE_LLM_MODEL=google/gemma-4-e4b
# VITE_LOCAL_LLM_PROXY_TARGET=http://your-llm-host:1234
# Leave VITE_LLM_BASE_URL unset in dev — Vite proxies /api/v1/chat to the target above
